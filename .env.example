VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# Server-side auth verification fallback (can be same as VITE_FIREBASE_API_KEY)
FIREBASE_WEB_API_KEY=your-api-key

# MongoDB Atlas Data API
# Example URL:
# https://data.mongodb-api.com/app/<your-app-id>/endpoint/data/v1/action/updateOne
MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/your-app-id/endpoint/data/v1/action/updateOne
MONGODB_DATA_API_KEY=your-mongodb-data-api-key
MONGODB_DATA_SOURCE=Cluster0
MONGODB_DATABASE=smartcampus
MONGODB_USERS_COLLECTION=users

# OpenRouter AI assistant
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional override (defaults to meta-llama/llama-3.1-8b-instruct)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# Set to "true" only for demos — production should keep AI behind Firebase sign-in (omit or false).
OPENROUTER_ALLOW_ANONYMOUS=

# Socket.IO peer chat (separate Node process). Production WebSockets URL for your deployed chat worker.
VITE_CHAT_SOCKET_URL=http://localhost:3001